# Copy to keystore.properties (gitignored) for command-line release builds.
#
#   cp keystore.properties.example keystore.properties
#
# Paths are relative to the project root (BeatIQ-App/). Use a gitignored .jks
# in the repo root, or an absolute path to a keystore outside the project.
#
# Android Studio "Generate Signed Bundle" can use any keystore path without this file.

storeFile=beatiq-upload.jks
storePassword=CHANGE_ME
keyAlias=beatiq
keyPassword=CHANGE_ME
