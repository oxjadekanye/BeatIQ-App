# Copy to keystore.properties (gitignored) for release signing.
#
#   cp keystore.properties.example keystore.properties
#
# storeFile MUST be the .jks or .keystore FILE — not a folder.
# If your keystore lives outside the project, use the full path (spaces are OK):

# Project copy (recommended for ./gradlew bundleRelease):
storeFile=beatiq-upload.jks

# Or the original file:
# storeFile=/Users/meedun/AndroidStudioProjects/BeatIQ Release file/Untitled.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD

# Find alias with:
#   keytool -list -v -keystore "/path/to/your.jks"
